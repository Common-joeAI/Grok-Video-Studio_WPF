<Application
    x:Class="GrokVideoStudio.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:helpers="clr-namespace:GrokVideoStudio.App.Helpers">

    <!--
      MODERNIZATION: The StartupUri is intentionally empty — we use
      App.xaml.cs OnStartup to build the DI container and show the
      main window programmatically (host-first approach).
    -->

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- WPF UI Fluent theme (replaces MahApps.Metro theme dictionaries) -->
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <!-- ── Shared Converters (used across all pages) ── -->
            <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />
            <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisConverter" />
            <helpers:InverseBoolToVisibilityConverter x:Key="InvertBoolToVisConverter" />
            <helpers:CountToVisibilityConverter x:Key="CountToVisConverter" />
            <helpers:StringToVisibilityConverter x:Key="StringToVisConverter" />
            <helpers:InvertStringToVisibilityConverter x:Key="InvertStringToVisConverter" />
            <helpers:StatusToIconConverter x:Key="StatusToIconConverter" />
            <helpers:StatusToColorConverter x:Key="StatusToColorConverter" />
            <helpers:BoolToVisibilityConverter x:Key="CustomBoolToVisConverter" />
            <helpers:StringToUriConverter x:Key="StringToUriConverter" />
            <helpers:LogLevelToBrushConverter x:Key="LogLevelToBrushConverter" />

            <!-- ── Shared Card Style (used across all pages) ── -->
            <Style x:Key="CardBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>

</Application>
