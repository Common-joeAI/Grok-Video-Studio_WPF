<ui:FluentWindow
    x:Class="GrokVideoStudio.App.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:pages="clr-namespace:GrokVideoStudio.App.Views.Pages"
    xmlns:helpers="clr-namespace:GrokVideoStudio.App.Helpers"
    xmlns:services="clr-namespace:GrokVideoStudio.Core.Services;assembly=GrokVideoStudio.Core"
    Title="Grok Video Studio"
    Width="1280"
    Height="820"
    MinWidth="900"
    MinHeight="600"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterScreen"
    Icon="pack://application:,,,/app.ico">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ── Navigation (main content) ── -->
        <ui:NavigationView
            x:Name="RootNavigation"
            Grid.Row="0"
            PaneDisplayMode="Left"
            IsPaneOpen="True">

            <ui:NavigationView.TitleBar>
                <ui:TitleBar Title="Grok Video Studio"
                        ShowMinimize="True"
                        ShowMaximize="True"
                        ShowClose="True">
                    <ui:TitleBar.Header>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0" helpers:StackPanelHelper.Spacing="8">
                            <Image Source="pack://application:,,,/app.ico" Width="20" Height="20" />
                            <TextBlock Text="Grok Video Studio" FontSize="14" FontWeight="Medium" VerticalAlignment="Center" />
                        </StackPanel>
                    </ui:TitleBar.Header>
                </ui:TitleBar>
            </ui:NavigationView.TitleBar>

            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="Generate" TargetPageType="{x:Type pages:GeneratePage}" Icon="{ui:SymbolIcon Filmstrip24}" />
                <ui:NavigationViewItem Content="Chain" TargetPageType="{x:Type pages:ChainPage}" Icon="{ui:SymbolIcon Link24}" />
                <ui:NavigationViewItem Content="Branding" TargetPageType="{x:Type pages:BrandingPage}" Icon="{ui:SymbolIcon Pen24}" />
                <ui:NavigationViewItem Content="History" TargetPageType="{x:Type pages:HistoryPage}" Icon="{ui:SymbolIcon Library24}" />
                <ui:NavigationViewItem Content="Player" TargetPageType="{x:Type pages:VideoPlayerPage}" Icon="{ui:SymbolIcon Video24}" />
                <ui:NavigationViewItem Content="Stitch" TargetPageType="{x:Type pages:StitchPage}" Icon="{ui:SymbolIcon Cut24}" />
                <ui:NavigationViewItem Content="Publish" TargetPageType="{x:Type pages:PublishPage}" Icon="{ui:SymbolIcon Share24}" />
            </ui:NavigationView.MenuItems>

            <ui:NavigationView.FooterMenuItems>
                <ui:NavigationViewItem Content="Activity Log" TargetPageType="{x:Type pages:ActivityLogPage}" Icon="{ui:SymbolIcon ArrowCounterclockwise24}" />
                <ui:NavigationViewItem Content="Settings" TargetPageType="{x:Type pages:SettingsPage}" Icon="{ui:SymbolIcon Settings24}" />
            </ui:NavigationView.FooterMenuItems>
        </ui:NavigationView>

        <!-- ── Live Activity Tracker ── -->
        <Grid Grid.Row="1" x:Name="ActivityTrackerPanel">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ── Collapsed strip (always visible) ── -->
            <Border Grid.Row="0"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="0,1,0,0"
                    Height="32">
                <Grid Margin="8,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Pulse indicator -->
                    <ui:SymbolIcon Grid.Column="0" Symbol="PresenceAvailable24" FontSize="12" Margin="0,0,8,0"
                                   Foreground="#4CAF50" VerticalAlignment="Center"
                                   x:Name="PulseIcon" />

                    <!-- Latest entry timestamp -->
                    <TextBlock Grid.Column="1"
                               Text="{Binding LatestEntry.Timestamp, StringFormat='{}{0:HH:mm:ss}', TargetNullValue='—'}"
                               FontFamily="Consolas" FontSize="11"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" MinWidth="56" />

                    <!-- Latest entry message -->
                    <TextBlock Grid.Column="2"
                               Text="{Binding LatestEntry.Message, TargetNullValue='Ready.'}"
                               FontFamily="Consolas" FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />

                    <!-- Error/Warning counters -->
                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                        <Border Background="#D32F2F" CornerRadius="8" Padding="6,1"
                                Visibility="{Binding ErrorCount, Converter={StaticResource CountToVisInvertedConverter}}">
                            <TextBlock Text="{Binding ErrorCount}" FontSize="10" Foreground="White" FontWeight="Bold" />
                        </Border>
                        <Border Background="#F57C00" CornerRadius="8" Padding="6,1" Margin="4,0,0,0"
                                Visibility="{Binding WarningCount, Converter={StaticResource CountToVisInvertedConverter}}">
                            <TextBlock Text="{Binding WarningCount}" FontSize="10" Foreground="White" FontWeight="Bold" />
                        </Border>
                    </StackPanel>

                    <!-- Clear button -->
                    <ui:Button Grid.Column="4" Appearance="Secondary" Padding="8,2" Margin="4,0"
                               Command="{Binding ClearCommand}" ToolTip="Clear activity tracker">
                        <ui:SymbolIcon Symbol="Delete24" FontSize="14" />
                    </ui:Button>

                    <!-- Expand/Collapse toggle -->
                    <ui:Button Grid.Column="5" Appearance="Secondary" Padding="8,2"
                               Command="{Binding ToggleExpandedCommand}" ToolTip="Expand/Collapse activity log">
                        <ui:SymbolIcon Symbol="ChevronUp24" FontSize="14"
                                       Visibility="{Binding IsExpanded, Converter={StaticResource CustomBoolToVisConverter}}" />
                        <ui:SymbolIcon Symbol="ChevronDown24" FontSize="14"
                                       Visibility="{Binding IsExpanded, Converter={StaticResource InverseBoolToVisConverter}}" />
                    </ui:Button>
                </Grid>
            </Border>

            <!-- ── Expanded panel (scrollable log) ── -->
            <Border Grid.Row="1"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="0,1,0,0"
                    Height="200"
                    Visibility="{Binding IsExpanded, Converter={StaticResource CustomBoolToVisConverter}}">
                <ListBox x:Name="TrackerLogList"
                         ItemsSource="{Binding RecentEntries}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="12,2" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="Focusable" Value="False" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type services:ActivityEntry}">
                            <Grid Margin="0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Timestamp -->
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss.fff}'}"
                                           FontFamily="Consolas" FontSize="11"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           VerticalAlignment="Top" Margin="0,0,12,0" />

                                <!-- Level badge -->
                                <Border Grid.Column="1"
                                        Background="{Binding Level, Converter={StaticResource LogLevelToBrushConverter}}"
                                        CornerRadius="3" Padding="5,1"
                                        HorizontalAlignment="Left" VerticalAlignment="Top"
                                        Margin="0,0,8,0">
                                    <TextBlock Text="{Binding Level}" FontSize="9" Foreground="White"
                                               FontWeight="SemiBold" HorizontalAlignment="Center" />
                                </Border>

                                <!-- Message -->
                                <TextBlock Grid.Column="2"
                                           Text="{Binding Message}"
                                           FontFamily="Consolas" FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap" VerticalAlignment="Top" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </Grid>

        <!-- ── Splash overlay (fades out after first navigation) ── -->
        <Grid x:Name="SplashOverlay"
              Grid.RowSpan="2"
              Background="#1A1A2E"
              VerticalAlignment="Stretch"
              HorizontalAlignment="Stretch"
              Opacity="1"
              Visibility="Visible">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Splash image -->
            <Image Grid.Row="1"
                   Source="pack://application:,,,/Assets/splash.png"
                   Stretch="Uniform"
                   MaxWidth="720"
                   MaxHeight="405"
                   Margin="48" />

            <!-- Loading indicator -->
            <StackPanel Grid.Row="2"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="0,0,0,48">
                <ui:ProgressRing IsIndeterminate="True" Width="28" Height="28" />
                <TextBlock Text="Loading…"
                           FontSize="13"
                           Opacity="0.6"
                           HorizontalAlignment="Center"
                           Margin="0,12,0,0" />
            </StackPanel>
        </Grid>
    </Grid>

</ui:FluentWindow>
