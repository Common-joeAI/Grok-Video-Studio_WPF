<Page
    x:Class="GrokVideoStudio.App.Views.Pages.ChainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:GrokVideoStudio.App.ViewModels"
    xmlns:helpers="clr-namespace:GrokVideoStudio.App.Helpers"
    d:DataContext="{d:DesignInstance Type=vm:ChainGenerationViewModel}"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Chain Generation">

    <!--
      Chain Generation page — audio-driven or manual multi-clip generation.
      Each clip continues from the last frame of the previous one,
      then all clips are stitched together with FFmpeg.
    -->

    <Page.Resources>
        <helpers:BoolToVisibilityConverter x:Key="ChainBoolToVis" />
    </Page.Resources>

    <Grid Margin="32,24,32,32">
        <StackPanel MaxWidth="820" helpers:StackPanelHelper.Spacing="20">

            <!-- ── Header ── -->
            <StackPanel helpers:StackPanelHelper.Spacing="4">
                <TextBlock Text="Chain Generation" FontSize="28" FontWeight="SemiBold" />
                <TextBlock Text="Generate multiple clips that chain together, then stitch into one video" FontSize="14" Opacity="0.6" />
            </StackPanel>

            <!-- ── Mode Toggle ── -->
            <Border Style="{StaticResource CardBorderStyle}" Padding="20" CornerRadius="8">
                <StackPanel helpers:StackPanelHelper.Spacing="12">
                    <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="8">
                        <ui:SymbolIcon Symbol="Beaker24" FontSize="18" />
                        <TextBlock Text="Generation Mode" FontWeight="Medium" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="16">
                        <RadioButton Content="Audio-Driven (upload MP3/WAV)" IsChecked="{Binding AudioDrivenMode}" />
                        <RadioButton Content="Manual (set clip count)" IsChecked="{Binding AudioDrivenMode, Converter={StaticResource InvertBoolToVisConverter}}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ── Audio Input (visible when audio-driven) ── -->
            <Border Style="{StaticResource CardBorderStyle}" Padding="20" CornerRadius="8"
                    Visibility="{Binding AudioDrivenMode, Converter={StaticResource ChainBoolToVis}}">
                <StackPanel helpers:StackPanelHelper.Spacing="12">
                    <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="8">
                        <ui:SymbolIcon Symbol="Audio24" FontSize="18" />
                        <TextBlock Text="Audio Source" FontWeight="Medium" />
                    </StackPanel>
                    <Grid ColumnDefinitions="*,Auto">
                        <ui:TextBox Grid.Column="0"
                            Text="{Binding AudioFilePath, Mode=OneWay}"
                            PlaceholderText="No audio file selected"
                            IsReadOnly="True" />
                        <ui:Button Grid.Column="1" Content="Browse" Command="{Binding BrowseAudioCommand}" Margin="8,0,0,0" Padding="16,6" />
                    </Grid>
                    <ui:TextBox PlaceholderText="Enter the concept/theme for your video (e.g., 'A journey through a neon city at night')"
                                Text="{Binding Concept, UpdateSourceTrigger=PropertyChanged}"
                                AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60" />
                    <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="16">
                        <TextBlock Text="Duration:" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding AudioDuration, StringFormat={}{0:F1}s}" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <TextBlock Text="Clips needed:" VerticalAlignment="Center" Margin="16,0,0,0" />
                        <TextBlock Text="{Binding CalculatedClipCount}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </StackPanel>
                    <ui:Button Content="Analyze &amp; Generate Scene Plan"
                               Icon="{ui:SymbolIcon Sparkle24}"
                               Appearance="Primary"
                               Command="{Binding AnalyzeAudioCommand}"
                               Padding="20,10" />
                </StackPanel>
            </Border>

            <!-- ── Manual Mode Input (visible when manual) ── -->
            <Border Style="{StaticResource CardBorderStyle}" Padding="20" CornerRadius="8"
                    Visibility="{Binding AudioDrivenMode, Converter={StaticResource InvertBoolToVisConverter}}">
                <StackPanel helpers:StackPanelHelper.Spacing="12">
                    <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="8">
                        <ui:SymbolIcon Symbol="Document24" FontSize="18" />
                        <TextBlock Text="Manual Chain" FontWeight="Medium" />
                    </StackPanel>
                    <ui:TextBox PlaceholderText="Enter base prompt for the first clip"
                                Text="{Binding BasePrompt, UpdateSourceTrigger=PropertyChanged}"
                                AcceptsReturn="True" TextWrapping="Wrap" MinHeight="80" />
                    <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="8">
                        <TextBlock Text="Clip count:" VerticalAlignment="Center" />
                        <ui:NumberBox Value="{Binding ManualClipCount}" Minimum="2" Maximum="20" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ── Generation Settings ── -->
            <Border Style="{StaticResource CardBorderStyle}" Padding="20" CornerRadius="8">
                <StackPanel helpers:StackPanelHelper.Spacing="12">
                    <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="8">
                        <ui:SymbolIcon Symbol="Settings24" FontSize="18" />
                        <TextBlock Text="Generation Settings" FontWeight="Medium" />
                    </StackPanel>
                    <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto,Auto" helpers:StackPanelHelper.Spacing="8">
                        <StackPanel Grid.Row="0" Grid.Column="0" helpers:StackPanelHelper.Spacing="4">
                            <TextBlock Text="Provider" FontSize="12" Opacity="0.6" />
                            <ComboBox ItemsSource="{Binding VideoProviders}" SelectedItem="{Binding SelectedProvider}" />
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,0" helpers:StackPanelHelper.Spacing="4">
                            <TextBlock Text="Model" FontSize="12" Opacity="0.6" />
                            <ComboBox ItemsSource="{Binding Models}" SelectedItem="{Binding SelectedModel}" />
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="8,0,0,0" helpers:StackPanelHelper.Spacing="4">
                            <TextBlock Text="Clip Duration" FontSize="12" Opacity="0.6" />
                            <ComboBox ItemsSource="{Binding ClipDurations}" SelectedItem="{Binding ClipDuration}" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,8,0,0" helpers:StackPanelHelper.Spacing="4">
                            <TextBlock Text="Aspect Ratio" FontSize="12" Opacity="0.6" />
                            <ComboBox ItemsSource="{Binding AspectRatios}" SelectedItem="{Binding AspectRatio}" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,8,0,0" helpers:StackPanelHelper.Spacing="4">
                            <TextBlock Text="Resolution" FontSize="12" Opacity="0.6" />
                            <ComboBox ItemsSource="{Binding Resolutions}" SelectedItem="{Binding Resolution}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── Scene Plan (visible when plan exists) ── -->
            <Border Style="{StaticResource CardBorderStyle}" Padding="20" CornerRadius="8"
                    Visibility="{Binding AudioDrivenMode, Converter={StaticResource ChainBoolToVis}}">
                <StackPanel helpers:StackPanelHelper.Spacing="8">
                    <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="8">
                        <ui:SymbolIcon Symbol="List24" FontSize="18" />
                        <TextBlock Text="Scene Plan" FontWeight="Medium" />
                    </StackPanel>
                    <ItemsControl ItemsSource="{Binding ScenePlan}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="0,0,0,1" Padding="0,8">
                                    <Grid ColumnDefinitions="32,*,Auto">
                                        <TextBlock Grid.Column="0" Text="{Binding Index}" FontWeight="SemiBold" FontSize="16" Opacity="0.7" />
                                        <StackPanel Grid.Column="1" helpers:StackPanelHelper.Spacing="2">
                                            <TextBlock Text="{Binding Prompt}" TextTrimming="CharacterEllipsis" MaxWidth="500" />
                                            <TextBlock Text="{Binding Mood}" FontSize="11" Opacity="0.5" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding StartTime, StringFormat={}{0:F0}s}" FontSize="12" Opacity="0.5" VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- ── Run / Cancel ── -->
            <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="12">
                <ui:Button Content="Run Chained Generation"
                           Icon="{ui:SymbolIcon Play24}"
                           Appearance="Primary"
                           Command="{Binding RunChainCommand}"
                           Padding="24,10" />
                <ui:Button Content="Cancel"
                           Appearance="Caution"
                           Command="{Binding CancelCommand}"
                           Padding="20,10" />
            </StackPanel>

            <!-- ── Progress ── -->
            <Border Style="{StaticResource CardBorderStyle}" Padding="20" CornerRadius="8"
                    Visibility="{Binding IsRunning, Converter={StaticResource ChainBoolToVis}}">
                <StackPanel helpers:StackPanelHelper.Spacing="8">
                    <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="8">
                        <TextBlock Text="Clip" FontWeight="Medium" />
                        <TextBlock Text="{Binding CurrentClip}" FontWeight="SemiBold" />
                        <TextBlock Text="of" />
                        <TextBlock Text="{Binding TotalClips}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding CurrentStage, StringFormat=' — {0}'}" Opacity="0.7" />
                    </StackPanel>
                    <ProgressBar Value="{Binding OverallProgress}" Maximum="100" Height="8" />
                    <TextBlock Text="{Binding StatusMessage}" FontSize="13" Opacity="0.7" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- ── Result ── -->
            <Border Style="{StaticResource CardBorderStyle}" Padding="20" CornerRadius="8"
                    Visibility="{Binding ResultVideoPath, Converter={StaticResource StringToVisConverter}}">
                <StackPanel helpers:StackPanelHelper.Spacing="8">
                    <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="8">
                        <ui:SymbolIcon Symbol="CheckmarkCircle24" FontSize="18" />
                        <TextBlock Text="Result" FontWeight="Medium" />
                    </StackPanel>
                    <TextBlock Text="{Binding ResultVideoPath}" TextWrapping="Wrap" Opacity="0.7" FontSize="13" />
                    <ui:Button Content="Open Video" Icon="{ui:SymbolIcon Open24}" Command="{Binding OpenResultCommand}" Padding="16,6" />
                </StackPanel>
            </Border>

            <!-- ── Status ── -->
            <TextBlock Text="{Binding StatusMessage}" FontSize="13" Opacity="0.6" TextWrapping="Wrap" />

        </StackPanel>
    </Grid>
</Page>
