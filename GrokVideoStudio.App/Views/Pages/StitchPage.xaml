<Page
    x:Class="GrokVideoStudio.App.Views.Pages.StitchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:GrokVideoStudio.App.ViewModels"
    xmlns:helpers="clr-namespace:GrokVideoStudio.App.Helpers"
    d:DataContext="{d:DesignInstance Type=vm:StitchViewModel}"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Stitch"
    Loaded="Page_Loaded">

    <!--
      Stitch page — combine clips with FFmpeg pipeline options.
      Icons: all use Segoe Fluent Icons via WPF UI SymbolIcon.
    -->

    <ScrollViewer Padding="32,24,32,32" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="720" helpers:StackPanelHelper.Spacing="20">

            <!-- ── Header ── -->
            <StackPanel helpers:StackPanelHelper.Spacing="4">
                <TextBlock Text="Stitch Videos" FontSize="28" FontWeight="SemiBold" />
                <TextBlock Text="Combine clips with crossfade, interpolation, upscale, and music" FontSize="14" Opacity="0.6" />
            </StackPanel>

            <!-- ── Available clips ── -->
            <Border Style="{StaticResource CardBorderStyle}" Padding="20" CornerRadius="8">
                <StackPanel helpers:StackPanelHelper.Spacing="12">
                    <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="8">
                        <ui:SymbolIcon Symbol="Library24" FontSize="16" />
                        <TextBlock Text="Available Clips" FontWeight="Medium" />
                    </StackPanel>
                    <ListBox x:Name="AvailableVideosList" ItemsSource="{Binding AvailableVideos}" Height="180">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="8">
                                    <ui:SymbolIcon Symbol="Filmstrip24" FontSize="14" Opacity="0.5" />
                                    <TextBlock Text="{Binding Prompt}" TextTrimming="CharacterEllipsis" MaxWidth="280" />
                                    <TextBlock Text="{Binding Duration, StringFormat='{}{0}s'}" Opacity="0.5" FontSize="12" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <ui:Button Content="Add Selected" Icon="{ui:SymbolIcon Add24}" Command="{Binding AddToStitchCommand}"
                               CommandParameter="{Binding SelectedItem, ElementName=AvailableVideosList}"
                               Appearance="Primary" />
                </StackPanel>
            </Border>

            <!-- ── Stitch queue ── -->
            <Border Style="{StaticResource CardBorderStyle}" Padding="20" CornerRadius="8">
                <StackPanel helpers:StackPanelHelper.Spacing="12">
                    <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="8">
                        <ui:SymbolIcon Symbol="List24" FontSize="16" />
                        <TextBlock Text="Stitch Queue" FontWeight="Medium" />
                    </StackPanel>
                    <ListBox ItemsSource="{Binding SelectedVideos}" Height="120">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="8">
                                    <ui:SymbolIcon Symbol="Filmstrip24" FontSize="14" Opacity="0.5" />
                                    <TextBlock Text="{Binding Prompt}" TextTrimming="CharacterEllipsis" MaxWidth="260" />
                                    <ui:Button Icon="{ui:SymbolIcon Dismiss24}" Appearance="Caution" FontSize="10" Padding="4,2"
                                               Command="{Binding DataContext.RemoveFromStitchCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                               CommandParameter="{Binding}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

            <!-- ── Pipeline options ── -->
            <Border Style="{StaticResource CardBorderStyle}" Padding="20" CornerRadius="8">
                <StackPanel helpers:StackPanelHelper.Spacing="16">
                    <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="8">
                        <ui:SymbolIcon Symbol="Options24" FontSize="16" />
                        <TextBlock Text="Pipeline Options" FontWeight="Medium" />
                    </StackPanel>

                    <CheckBox Content="Crossfade transitions" IsChecked="{Binding EnableCrossfade}" />

                    <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="12">
                        <TextBlock Text="Interpolation FPS" VerticalAlignment="Center" Width="140" />
                        <ComboBox ItemsSource="{Binding FpsOptions}" SelectedItem="{Binding InterpolationFps}" MinWidth="100" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="12">
                        <TextBlock Text="Upscale" VerticalAlignment="Center" Width="140" />
                        <ComboBox ItemsSource="{Binding UpscalePresets}" SelectedItem="{Binding UpscalePreset}" MinWidth="100" />
                    </StackPanel>

                    <CheckBox Content="GPU encode (NVENC)" IsChecked="{Binding EnableGpuEncode}" />

                    <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="12">
                        <ui:SymbolIcon Symbol="MusicNote224" FontSize="16" VerticalAlignment="Center" />
                        <TextBlock Text="Music mix" VerticalAlignment="Center" Width="120" />
                        <ui:Button Content="Browse…" Icon="{ui:SymbolIcon FolderOpen24}" Command="{Binding BrowseMusicCommand}" />
                        <TextBlock Text="{Binding MusicMixPath}" Opacity="0.5" TextTrimming="CharacterEllipsis" MaxWidth="200" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <ui:Button Content="Stitch &amp; Export" Icon="{ui:SymbolIcon Cut24}" Appearance="Primary"
                       Command="{Binding StitchCommand}" Padding="24,10" />

            <TextBlock Text="{Binding StatusMessage}" Opacity="0.7" TextWrapping="Wrap" />

        </StackPanel>
    </ScrollViewer>
</Page>
