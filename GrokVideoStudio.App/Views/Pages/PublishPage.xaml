<Page
    x:Class="GrokVideoStudio.App.Views.Pages.PublishPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:GrokVideoStudio.App.ViewModels"
    xmlns:helpers="clr-namespace:GrokVideoStudio.App.Helpers"
    d:DataContext="{d:DesignInstance Type=vm:PublishViewModel}"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Publish"
    Loaded="Page_Loaded">

    <!--
      Publish page — upload videos to social platforms or export to a local folder.
    -->

    <Grid Margin="32,24,32,32">
        <StackPanel MaxWidth="720" helpers:StackPanelHelper.Spacing="20">

            <!-- ── Header ── -->
            <StackPanel helpers:StackPanelHelper.Spacing="4">
                <TextBlock Text="Publish" FontSize="28" FontWeight="SemiBold" />
                <TextBlock Text="Upload your video to social platforms or save to a folder" FontSize="14" Opacity="0.6" />
            </StackPanel>

            <!-- ── Source video ── -->
            <Border Style="{StaticResource CardBorderStyle}" Padding="20" CornerRadius="8">
                <StackPanel helpers:StackPanelHelper.Spacing="12">
                    <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="8">
                        <ui:SymbolIcon Symbol="VideoClip24" FontSize="16" />
                        <TextBlock Text="Source Video" FontWeight="Medium" />
                    </StackPanel>
                    <ComboBox ItemsSource="{Binding AvailableVideos}"
                                 SelectedItem="{Binding SelectedVideo}"
                                 DisplayMemberPath="Prompt"
                                 MinWidth="400" />
                </StackPanel>
            </Border>

            <!-- ── Platform & metadata ── -->
            <Border Style="{StaticResource CardBorderStyle}" Padding="20" CornerRadius="8">
                <StackPanel helpers:StackPanelHelper.Spacing="16">
                    <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="8">
                        <ui:SymbolIcon Symbol="Share24" FontSize="16" />
                        <TextBlock Text="Platform &amp; Metadata" FontWeight="Medium" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="12">
                        <ui:SymbolIcon Symbol="Globe24" FontSize="16" VerticalAlignment="Center" />
                        <TextBlock Text="Platform" VerticalAlignment="Center" Width="90" />
                        <ComboBox ItemsSource="{Binding Platforms}" SelectedItem="{Binding SelectedPlatform}" MinWidth="160" />
                    </StackPanel>

                    <!-- ── Folder picker (visible only in Folder mode) ── -->
                    <StackPanel helpers:StackPanelHelper.Spacing="6"
                                Visibility="{Binding IsFolderMode, Converter={StaticResource CustomBoolToVisConverter}}">
                        <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="6">
                            <ui:SymbolIcon Symbol="FolderOpen24" FontSize="14" />
                            <TextBlock Text="Destination Folder" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="8">
                            <ui:TextBox Text="{Binding TargetFolder, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="Select a destination folder…"
                                        MinWidth="400"
                                        IsReadOnly="True" />
                            <ui:Button Content="Browse…" Icon="{ui:SymbolIcon FolderOpen24}"
                                       Command="{Binding BrowseFolderCommand}"
                                       Padding="16,6" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel helpers:StackPanelHelper.Spacing="6">
                        <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="6">
                            <ui:SymbolIcon Symbol="TextDescription24" FontSize="14" />
                            <TextBlock Text="Title" />
                        </StackPanel>
                        <ui:TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Video title…" />
                    </StackPanel>

                    <StackPanel helpers:StackPanelHelper.Spacing="6">
                        <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="6">
                            <ui:SymbolIcon Symbol="TextAlignLeft24" FontSize="14" />
                            <TextBlock Text="Description" />
                        </StackPanel>
                        <ui:TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="Description…"
                                    AcceptsReturn="True"
                                    TextWrapping="Wrap"
                                    MinHeight="80" />
                    </StackPanel>

                    <StackPanel helpers:StackPanelHelper.Spacing="6">
                        <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="6">
                            <ui:SymbolIcon Symbol="Tag24" FontSize="14" />
                            <TextBlock Text="Tags (comma-separated)" />
                        </StackPanel>
                        <ui:TextBox Text="{Binding Tags, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="tag1, tag2, tag3" />
                    </StackPanel>

                    <!-- Browser automation toggle (hidden in Folder mode — no browser needed) -->
                    <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="8"
                                Visibility="{Binding IsFolderMode, Converter={StaticResource InverseBoolToVisConverter}}">
                        <ui:SymbolIcon Symbol="Desktop24" FontSize="16" />
                        <CheckBox Content="Use browser automation (instead of API)" IsChecked="{Binding UseBrowserAutomation}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <ui:Button Content="Publish Video" Icon="{ui:SymbolIcon Send24}" Appearance="Primary"
                       Command="{Binding PublishCommand}" Padding="24,10" />

            <TextBlock Text="{Binding StatusMessage}" Opacity="0.7" TextWrapping="Wrap" />

        </StackPanel>
    </Grid>
</Page>
