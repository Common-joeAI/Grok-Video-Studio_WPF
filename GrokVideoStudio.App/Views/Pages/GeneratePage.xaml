<Page
    x:Class="GrokVideoStudio.App.Views.Pages.GeneratePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:GrokVideoStudio.App.ViewModels"
    xmlns:helpers="clr-namespace:GrokVideoStudio.App.Helpers"
    xmlns:sys="clr-namespace:System.Windows.Controls;assembly=PresentationFramework"
    d:DataContext="{d:DesignInstance Type=vm:GenerateViewModel}"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Generate">

    <!--
      FULL FEATURE PARITY Generate page:
      - Prompt source selector (Manual, Grok API, OpenAI, Ollama) + concept + generate prompt
      - Video provider (Grok, Sora, Seedance) + model + duration + ratio + resolution
      - Batch variant count (generate N variants)
      - Image-to-video (browse image)
      - Continue from last frame (extract last frame from previous video)
      - Progress + cancellation
      - Batch results list
    -->

    <ScrollViewer Padding="32,24,32,32" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="720" helpers:StackPanelHelper.Spacing="20">

            <!-- ── Header ── -->
            <StackPanel helpers:StackPanelHelper.Spacing="4">
                <TextBlock Text="Generate Video" FontSize="28" FontWeight="SemiBold" />
                <TextBlock Text="Create AI videos using Grok Imagine, Sora 2, or Seedance" FontSize="14" Opacity="0.6" />
            </StackPanel>

            <!-- ── Prompt Section ── -->
            <Border Style="{StaticResource CardBorderStyle}" Padding="20" CornerRadius="8">
                <StackPanel helpers:StackPanelHelper.Spacing="12">
                    <TextBlock Text="Prompt" FontWeight="Medium" />

                    <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="12">
                        <TextBlock Text="Source" VerticalAlignment="Center" Width="60" />
                        <ComboBox ItemsSource="{Binding PromptSources}" SelectedItem="{Binding SelectedPromptSource}" MinWidth="160" />
                        <ui:Button Content="Generate Prompt" Icon="{ui:SymbolIcon Sparkle24}"
                                   Command="{Binding GeneratePromptCommand}" Appearance="Secondary" />
                    </StackPanel>

                    <ui:TextBox Text="{Binding Concept, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="Enter a concept (e.g. 'a cat playing piano on Mars')…" />

                    <ui:TextBox Text="{Binding Prompt, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="Detailed video prompt…"
                                AcceptsReturn="True" TextWrapping="Wrap" MinHeight="100" VerticalContentAlignment="Top" />
                </StackPanel>
            </Border>

            <!-- ── Provider Settings ── -->
            <Border Style="{StaticResource CardBorderStyle}" Padding="20" CornerRadius="8">
                <Grid ColumnDefinitions="Auto,Auto,*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Provider" FontWeight="Medium" Margin="0,0,16,12" VerticalAlignment="Center" />
                    <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding VideoProviders}" SelectedItem="{Binding SelectedProvider}" MinWidth="180" Margin="0,0,24,12" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Model" FontWeight="Medium" Margin="0,0,16,12" VerticalAlignment="Center" />
                    <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding Models}" SelectedItem="{Binding SelectedModel}" MinWidth="220" Margin="0,0,24,12" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Duration" FontWeight="Medium" Margin="0,0,16,12" VerticalAlignment="Center" />
                    <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" helpers:StackPanelHelper.Spacing="12" Margin="0,0,24,12">
                        <ComboBox ItemsSource="{Binding Durations}" SelectedItem="{Binding Duration}" MinWidth="80" />
                        <TextBlock Text="seconds" Opacity="0.6" VerticalAlignment="Center" />
                    </StackPanel>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Aspect Ratio" FontWeight="Medium" Margin="0,0,16,12" VerticalAlignment="Center" />
                    <ComboBox Grid.Row="3" Grid.Column="1" ItemsSource="{Binding AspectRatios}" SelectedItem="{Binding AspectRatio}" MinWidth="120" Margin="0,0,24,12" />

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Resolution" FontWeight="Medium" Margin="0,0,16,12" VerticalAlignment="Center" />
                    <ComboBox Grid.Row="4" Grid.Column="1" ItemsSource="{Binding Resolutions}" SelectedItem="{Binding Resolution}" MinWidth="120" Margin="0,0,24,12" />

                    <!-- Batch variant count -->
                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Variants" FontWeight="Medium" Margin="0,0,16,12" VerticalAlignment="Center" />
                    <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" helpers:StackPanelHelper.Spacing="12" Margin="0,0,24,12">
                        <ComboBox ItemsSource="{Binding VariantCounts}" SelectedItem="{Binding VariantCount}" MinWidth="80" />
                        <TextBlock Text="videos at once" Opacity="0.6" VerticalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Image-to-Video + Continue ── -->
            <Border Style="{StaticResource CardBorderStyle}" Padding="20" CornerRadius="8">
                <StackPanel helpers:StackPanelHelper.Spacing="12">
                    <TextBlock Text="Image Source (Optional)" FontWeight="Medium" />
                    <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="12">
                        <ui:Button Content="Browse Image…" Icon="{ui:SymbolIcon Image24}" Command="{Binding BrowseImageCommand}" />
                        <ui:Button Content="Continue from Last Frame" Icon="{ui:SymbolIcon Previous24}"
                                   Command="{Binding ContinueFromLastFrameCommand}" Appearance="Secondary" />
                        <ui:Button Content="Clear" Appearance="Secondary" Command="{Binding ClearImageCommand}" />
                    </StackPanel>
                    <TextBlock Text="{Binding SourceImagePath}" Opacity="0.5" FontSize="13" TextTrimming="CharacterEllipsis"
                               Visibility="{Binding SourceImagePath, Converter={StaticResource StringToVisConverter}}" />
                    <TextBlock Text="{Binding LastFrameImagePath}" Opacity="0.5" FontSize="13" TextTrimming="CharacterEllipsis"
                               Visibility="{Binding ContinueFromLastFrame, Converter={StaticResource BoolToVisConverter}}" />
                    <CheckBox Content="Use last frame for this generation" IsChecked="{Binding ContinueFromLastFrame}" />
                </StackPanel>
            </Border>

            <!-- ── Generate / Cancel ── -->
            <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="12">
                <ui:Button Content="Generate Video" Icon="{ui:SymbolIcon Play24}" Appearance="Primary"
                           Command="{Binding GenerateCommand}" Padding="24,10" />
                <ui:Button Content="Cancel" Appearance="Caution" Command="{Binding CancelCommand}" Padding="20,10" />
            </StackPanel>

            <!-- ── Progress ── -->
            <Border Style="{StaticResource CardBorderStyle}" Padding="20" CornerRadius="8"
                    Visibility="{Binding IsGenerating, Converter={StaticResource BoolToVisConverter}}">
                <StackPanel helpers:StackPanelHelper.Spacing="12">
                    <ProgressBar Value="{Binding ProgressValue}" Maximum="100" Height="6" />
                    <TextBlock Text="{Binding StatusMessage}" FontSize="13" Opacity="0.7" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding StatusMessage}" FontSize="13" Opacity="0.7" TextWrapping="Wrap"
                        Visibility="{Binding IsGenerating, Converter={StaticResource InvertBoolToVisConverter}}" />

            <!-- ── Batch Results ── -->
            <Border Style="{StaticResource CardBorderStyle}" Padding="20" CornerRadius="8"
                    Visibility="{Binding BatchResults.Count, Converter={StaticResource CountToVisConverter}}">
                <StackPanel helpers:StackPanelHelper.Spacing="12">
                    <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="8">
                        <ui:SymbolIcon Symbol="CheckmarkCircle24" Foreground="#4CAF50" FontSize="20" />
                        <TextBlock Text="Batch Results" FontWeight="SemiBold" FontSize="16" />
                    </StackPanel>
                    <ItemsControl ItemsSource="{Binding BatchResults}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="12" Margin="0,4">
                                    <ui:SymbolIcon Symbol="VideoClip24" FontSize="16" Opacity="0.5" />
                                    <TextBlock Text="{Binding Prompt}" TextTrimming="CharacterEllipsis" MaxWidth="300" />
                                    <TextBlock Text="{Binding ResultVideoUrl}" Opacity="0.5" FontSize="12" TextTrimming="CharacterEllipsis" MaxWidth="250" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            </StackPanel>
            </ScrollViewer>
        </Page>