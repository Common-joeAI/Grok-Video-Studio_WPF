<Page
    x:Class="GrokVideoStudio.App.Views.Pages.HistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:GrokVideoStudio.App.ViewModels"
    d:DataContext="{d:DesignInstance Type=vm:HistoryViewModel}"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="History"
    Loaded="Page_Loaded">

    <!--
      History page with thumbnail previews, status indicators, and per-video actions.
      FEATURE PARITY: Original Python app has a "Generated Videos" picker with thumbnails.
    -->

    <Grid Margin="32,24,32,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20" Spacing="16">
            <StackPanel Spacing="4">
                <TextBlock Text="Video History" FontSize="28" FontWeight="SemiBold" />
                <TextBlock Text="All your past generations — click to preview, download, or publish" FontSize="14" Opacity="0.6" />
            </StackPanel>
            <ui:Button Content="Refresh" Icon="{ui:SymbolIcon ArrowSync24}"
                       Command="{Binding RefreshCommand}" VerticalAlignment="Bottom" Margin="0,0,0,4" />
            <TextBlock Text="{Binding StatusMessage}" Opacity="0.7" FontSize="13" VerticalAlignment="Bottom" Margin="0,0,0,4" />
        </StackPanel>

        <!-- ── Video Grid with Thumbnails ── -->
        <ListView
            Grid.Row="1"
            ItemsSource="{Binding Videos}"
            SelectedItem="{Binding SelectedVideo}"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled">

            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Width="280" Margin="0,0,12,12" Padding="0" CornerRadius="8"
                            Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <!-- Thumbnail -->
                            <Border Height="140" CornerRadius="8,8,0,0" ClipToBounds="True">
                                <Grid>
                                    <!-- Thumbnail image (if available) -->
                                    <Image Source="{Binding ThumbnailPath}"
                                           Stretch="UniformToFill" Height="140"
                                           Visibility="{Binding ThumbnailPath, Converter={StaticResource StringToVisConverter}}" />
                                    <!-- Placeholder when no thumbnail -->
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                                Visibility="{Binding ThumbnailPath, Converter={StaticResource InvertStringToVisConverter}}">
                                        <ui:SymbolIcon Symbol="Film24" FontSize="36" Opacity="0.3" />
                                    </StackPanel>
                                    <!-- Status badge overlay -->
                                    <Border VerticalAlignment="Top" HorizontalAlignment="Right" Margin="6"
                                            Padding="6,2" CornerRadius="4" Background="#99000000">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <ui:SymbolIcon
                                                Symbol="{Binding Status, Converter={StaticResource StatusToIconConverter}}"
                                                FontSize="12"
                                                Foreground="{Binding Status, Converter={StaticResource StatusToColorConverter}}" />
                                            <TextBlock Text="{Binding Status}" FontSize="10" Foreground="White" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- Info -->
                            <StackPanel Padding="12,8" Spacing="4">
                                <TextBlock Text="{Binding Prompt}" TextTrimming="CharacterEllipsis"
                                           MaxLines="2" FontSize="13" FontWeight="Medium" />
                                <StackPanel Orientation="Horizontal" Spacing="8" Opacity="0.5" FontSize="11">
                                    <TextBlock Text="{Binding Model}" />
                                    <TextBlock Text="{Binding Duration, StringFormat='{}{0}s'}" />
                                    <TextBlock Text="{Binding Resolution}" />
                                </StackPanel>
                                <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:MMM dd, HH:mm}'}"
                                           Opacity="0.4" FontSize="11" />

                                <!-- Actions -->
                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                                    <ui:Button Content="Open" Icon="{ui:SymbolIcon Open24}" Appearance="Secondary"
                                               Command="{Binding DataContext.OpenLocalVideoCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                               CommandParameter="{Binding}" Padding="6,3" FontSize="11" />
                                    <ui:Button Content="URL" Icon="{ui:SymbolIcon Link24}" Appearance="Secondary"
                                               Command="{Binding DataContext.OpenVideoUrlCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                               CommandParameter="{Binding}" Padding="6,3" FontSize="11" />
                                    <ui:Button Content="DL" Icon="{ui:SymbolIcon Download24}" Appearance="Secondary"
                                               Command="{Binding DataContext.DownloadVideoCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                               CommandParameter="{Binding}" Padding="6,3" FontSize="11" />
                                    <ui:Button Content="Del" Icon="{ui:SymbolIcon Delete24}" Appearance="Caution"
                                               Command="{Binding DataContext.DeleteVideoCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                               CommandParameter="{Binding}" Padding="6,3" FontSize="11" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- ── Empty State ── -->
        <Border Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                Visibility="{Binding Videos.Count, Converter={StaticResource CountToVisConverter}}">
            <StackPanel Spacing="12" HorizontalAlignment="Center">
                <ui:SymbolIcon Symbol="Film24" FontSize="48" Opacity="0.3" />
                <TextBlock Text="No videos yet. Generate one to get started!" Opacity="0.5" FontSize="14" HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

    </Grid>

    <Page.Resources>
        <local:StatusToIconConverter x:Key="StatusToIconConverter" xmlns:local="clr-namespace:GrokVideoStudio.App.Helpers" />
        <local:StatusToColorConverter x:Key="StatusToColorConverter" xmlns:local="clr-namespace:GrokVideoStudio.App.Helpers" />
        <local:CountToVisibilityConverter x:Key="CountToVisConverter" xmlns:local="clr-namespace:GrokVideoStudio.App.Helpers" />
        <ui:StringToVisibilityConverter x:Key="StringToVisConverter" />
        <local:InvertStringToVisibilityConverter x:Key="InvertStringToVisConverter" xmlns:local="clr-namespace:GrokVideoStudio.App.Helpers" />
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Page.Resources>
</Page>
