<Page
    x:Class="GrokVideoStudio.App.Views.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:GrokVideoStudio.App.ViewModels"
    d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Settings">

    <ScrollViewer Padding="32,24,32,32" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="720" Spacing="20">

            <StackPanel Spacing="4">
                <TextBlock Text="Settings" FontSize="28" FontWeight="SemiBold" />
                <TextBlock Text="Configure API keys, models, and pipeline defaults" FontSize="14" Opacity="0.6" />
            </StackPanel>

            <!-- xAI Grok -->
            <Border Style="{StaticResource CardBorderStyle}" Padding="20" CornerRadius="8">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ui:SymbolIcon Symbol="Key24" FontSize="18" />
                        <TextBlock Text="xAI Grok API" FontWeight="Medium" />
                    </StackPanel>
                    <ui:PasswordBox Password="{Binding GrokApiKey, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="xai-…" />
                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">
                        <TextBlock Grid.Row="0" Text="Chat Model" VerticalAlignment="Center" Margin="0,0,16,10" />
                        <ui:TextBox Grid.Row="0" Grid.Column="1" Text="{Binding GrokChatModel}" Margin="0,0,0,10" />
                        <TextBlock Grid.Row="1" Text="Video Model" VerticalAlignment="Center" Margin="0,0,16,10" />
                        <ui:TextBox Grid.Row="1" Grid.Column="1" Text="{Binding GrokVideoModel}" Margin="0,0,0,10" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- OpenAI -->
            <Border Style="{StaticResource CardBorderStyle}" Padding="20" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock Text="OpenAI API" FontWeight="Medium" />
                    <ui:PasswordBox Password="{Binding OpenAiApiKey, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="sk-…" />
                    <Grid ColumnDefinitions="Auto,*">
                        <TextBlock Text="Chat Model" VerticalAlignment="Center" Margin="0,0,16,0" />
                        <ui:TextBox Grid.Column="1" Text="{Binding OpenAiChatModel}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Ollama -->
            <Border Style="{StaticResource CardBorderStyle}" Padding="20" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock Text="Ollama (Local)" FontWeight="Medium" />
                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">
                        <TextBlock Grid.Row="0" Text="API Base" VerticalAlignment="Center" Margin="0,0,16,10" />
                        <ui:TextBox Grid.Row="0" Grid.Column="1" Text="{Binding OllamaApiBase}" Margin="0,0,0,10" />
                        <TextBlock Grid.Row="1" Text="Model" VerticalAlignment="Center" Margin="0,0,16,10" />
                        <ui:TextBox Grid.Row="1" Grid.Column="1" Text="{Binding OllamaChatModel}" Margin="0,0,0,10" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Seedance -->
            <Border Style="{StaticResource CardBorderStyle}" Padding="20" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock Text="Seedance API" FontWeight="Medium" />
                    <ui:PasswordBox Password="{Binding SeedanceApiKey, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Seedance key…" />
                </StackPanel>
            </Border>

            <!-- Social Publishing -->
            <Border Style="{StaticResource CardBorderStyle}" Padding="20" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock Text="Social Publishing" FontWeight="Medium" />
                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
                        <TextBlock Grid.Row="0" Text="YouTube API" VerticalAlignment="Center" Margin="0,0,16,10" />
                        <ui:TextBox Grid.Row="0" Grid.Column="1" Text="{Binding YouTubeApiKey}" Margin="0,0,0,10" />
                        <TextBlock Grid.Row="1" Text="FB Token" VerticalAlignment="Center" Margin="0,0,16,10" />
                        <ui:PasswordBox Grid.Row="1" Grid.Column="1" Password="{Binding FacebookAccessToken}" Margin="0,0,0,10" />
                        <TextBlock Grid.Row="2" Text="FB Page ID" VerticalAlignment="Center" Margin="0,0,16,10" />
                        <ui:TextBox Grid.Row="2" Grid.Column="1" Text="{Binding FacebookPageId}" Margin="0,0,0,10" />
                        <TextBlock Grid.Row="3" Text="IG User ID" VerticalAlignment="Center" Margin="0,0,16,10" />
                        <ui:TextBox Grid.Row="3" Grid.Column="1" Text="{Binding InstagramUserId}" Margin="0,0,0,10" />
                        <TextBlock Grid.Row="4" Text="IG Token" VerticalAlignment="Center" Margin="0,0,16,10" />
                        <ui:PasswordBox Grid.Row="4" Grid.Column="1" Password="{Binding InstagramAccessToken}" Margin="0,0,0,10" />
                        <TextBlock Grid.Row="5" Text="TikTok Token" VerticalAlignment="Center" Margin="0,0,16,10" />
                        <ui:PasswordBox Grid.Row="5" Grid.Column="1" Password="{Binding TikTokAccessToken}" Margin="0,0,0,10" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Generation defaults -->
            <Border Style="{StaticResource CardBorderStyle}" Padding="20" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock Text="Generation Defaults" FontWeight="Medium" />
                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                        <TextBlock Grid.Row="0" Text="Duration (s)" VerticalAlignment="Center" Margin="0,0,16,10" />
                        <ui:NumberBox Grid.Row="0" Grid.Column="1" Value="{Binding DefaultDuration}" Minimum="1" Maximum="15" Margin="0,0,0,10" />
                        <TextBlock Grid.Row="1" Text="Aspect Ratio" VerticalAlignment="Center" Margin="0,0,16,10" />
                        <ui:ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding AspectRatios}" SelectedItem="{Binding DefaultAspectRatio}" Margin="0,0,0,10" />
                        <TextBlock Grid.Row="2" Text="Resolution" VerticalAlignment="Center" Margin="0,0,16,10" />
                        <ui:ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding Resolutions}" SelectedItem="{Binding DefaultResolution}" Margin="0,0,0,10" />
                        <TextBlock Grid.Row="3" Text="Poll Interval (s)" VerticalAlignment="Center" Margin="0,0,16,10" />
                        <ui:NumberBox Grid.Row="3" Grid.Column="1" Value="{Binding PollIntervalSeconds}" Minimum="2" Maximum="60" Margin="0,0,0,10" />
                        <TextBlock Grid.Row="4" Text="Max Poll Attempts" VerticalAlignment="Center" Margin="0,0,16,10" />
                        <ui:NumberBox Grid.Row="4" Grid.Column="1" Value="{Binding MaxPollAttempts}" Minimum="10" Maximum="500" Margin="0,0,0,10" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Theme -->
            <Border Style="{StaticResource CardBorderStyle}" Padding="20" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock Text="Theme" FontWeight="Medium" />
                    <ui:ComboBox ItemsSource="{Binding Themes}" SelectedItem="{Binding Theme}" />
                </StackPanel>
            </Border>

            <!-- Save -->
            <StackPanel Orientation="Horizontal" Spacing="16">
                <ui:Button Content="Save Settings" Icon="{ui:SymbolIcon Save24}" Appearance="Primary"
                           Command="{Binding SaveCommand}" Padding="24,10" />
                <ui:Button Content="Clear All Keys" Icon="{ui:SymbolIcon Delete24}" Appearance="Caution"
                           Command="{Binding ClearAllKeysCommand}" Padding="16,8" />
                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" Opacity="0.7" FontSize="13" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>

    <Page.Resources>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Page.Resources>
</Page>
