<Page
    x:Class="GrokVideoStudio.App.Views.Pages.BrandingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:GrokVideoStudio.App.ViewModels"
    xmlns:helpers="clr-namespace:GrokVideoStudio.App.Helpers"
    xmlns:models="clr-namespace:GrokVideoStudio.Core.Models;assembly=GrokVideoStudio.Core"
    d:DataContext="{d:DesignInstance Type=vm:BrandingViewModel}"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Branding">

    <!--
      Branding page — configure brand identity applied to all generated videos.
      Logo overlay, watermark, color grading, audio identity, and video bumpers.
    -->

    <Page.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BrandBoolToVis" />
    </Page.Resources>

    <Grid Margin="32,24,32,32">
        <StackPanel MaxWidth="820" helpers:StackPanelHelper.Spacing="20">

            <!-- ── Header ── -->
            <StackPanel helpers:StackPanelHelper.Spacing="4">
                <TextBlock Text="Branding" FontSize="28" FontWeight="SemiBold" />
                <TextBlock Text="Define your brand identity — applied to every generated video" FontSize="14" Opacity="0.6" />
            </StackPanel>

            <!-- ── Master Toggle ── -->
            <Border Style="{StaticResource CardBorderStyle}" Padding="20" CornerRadius="8">
                <StackPanel helpers:StackPanelHelper.Spacing="12">
                    <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="8">
                        <ui:SymbolIcon Symbol="PaintBrush24" FontSize="18" />
                        <TextBlock Text="Brand Identity" FontWeight="Medium" />
                    </StackPanel>
                    <ui:TextBox PlaceholderText="Brand name (e.g. My Channel)" Text="{Binding BrandName, UpdateSourceTrigger=PropertyChanged}" />
                    <CheckBox Content="Apply branding to all generated videos" IsChecked="{Binding ApplyToAllVideos}" />
                </StackPanel>
            </Border>

            <!-- ── Colors ── -->
            <Border Style="{StaticResource CardBorderStyle}" Padding="20" CornerRadius="8">
                <StackPanel helpers:StackPanelHelper.Spacing="12">
                    <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="8">
                        <ui:SymbolIcon Symbol="Color24" FontSize="18" />
                        <TextBlock Text="Brand Colors" FontWeight="Medium" />
                    </StackPanel>
                    <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*" helpers:StackPanelHelper.Spacing="8">
                        <TextBlock Grid.Column="0" Text="Primary" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <ui:TextBox Grid.Column="1" Text="{Binding PrimaryColor, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Column="2" Text="Accent" VerticalAlignment="Center" Margin="8,0,8,0" />
                        <ui:TextBox Grid.Column="3" Text="{Binding SecondaryColor, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Column="4" Text="BG" VerticalAlignment="Center" Margin="8,0,8,0" />
                        <ui:TextBox Grid.Column="5" Text="{Binding BackgroundColor, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                    <TextBlock Text="Used for watermark text, overlays, and UI theming" FontSize="12" Opacity="0.5" />
                </StackPanel>
            </Border>

            <!-- ── Logo / Iconography ── -->
            <Border Style="{StaticResource CardBorderStyle}" Padding="20" CornerRadius="8">
                <StackPanel helpers:StackPanelHelper.Spacing="12">
                    <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="8">
                        <ui:SymbolIcon Symbol="Image24" FontSize="18" />
                        <TextBlock Text="Logo &amp; Iconography" FontWeight="Medium" />
                    </StackPanel>
                    <Grid ColumnDefinitions="*,Auto,Auto">
                        <ui:TextBox Grid.Column="0"
                            Text="{Binding LogoPath, Mode=OneWay}"
                            PlaceholderText="No logo selected"
                            IsReadOnly="True" />
                        <ui:Button Grid.Column="1" Content="Browse" Command="{Binding BrowseLogoCommand}" Margin="8,0,0,0" Padding="16,6" />
                        <ui:Button Grid.Column="2" Content="Clear" Command="{Binding ClearLogoCommand}" Margin="8,0,0,0" Padding="16,6" Appearance="Secondary" />
                    </Grid>
                    <Grid ColumnDefinitions="*,*,*,*" RowDefinitions="Auto,Auto,Auto,Auto" helpers:StackPanelHelper.Spacing="8">
                        <StackPanel Grid.Row="0" Grid.Column="0" helpers:StackPanelHelper.Spacing="4">
                            <TextBlock Text="Position" FontSize="12" Opacity="0.6" />
                            <ui:ComboBox ItemsSource="{Binding Positions}" SelectedItem="{Binding LogoPosition}" />
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,0" helpers:StackPanelHelper.Spacing="4">
                            <TextBlock Text="Opacity" FontSize="12" Opacity="0.6" />
                            <Slider Value="{Binding LogoOpacity}" Minimum="0.1" Maximum="1.0" TickFrequency="0.1" TickPlacement="BottomRight" Width="120" />
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="8,0,0,0" helpers:StackPanelHelper.Spacing="4">
                            <TextBlock Text="Scale (% width)" FontSize="12" Opacity="0.6" />
                            <Slider Value="{Binding LogoScale}" Minimum="0.05" Maximum="0.5" TickFrequency="0.05" TickPlacement="BottomRight" Width="120" />
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="3" Margin="8,0,0,0" helpers:StackPanelHelper.Spacing="4">
                            <TextBlock Text="Padding (px)" FontSize="12" Opacity="0.6" />
                            <ui:NumberBox Value="{Binding LogoPadding}" Minimum="0" Maximum="100" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── Watermark ── -->
            <Border Style="{StaticResource CardBorderStyle}" Padding="20" CornerRadius="8">
                <StackPanel helpers:StackPanelHelper.Spacing="12">
                    <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="8">
                        <ui:SymbolIcon Symbol="TextDescription24" FontSize="18" />
                        <TextBlock Text="Watermark" FontWeight="Medium" />
                    </StackPanel>
                    <ui:TextBox PlaceholderText="Watermark text (e.g. @mychannel or brand URL)"
                                Text="{Binding WatermarkText, UpdateSourceTrigger=PropertyChanged}" />
                    <Grid ColumnDefinitions="*,*,*,*"> 
                        <StackPanel Grid.Column="0" helpers:StackPanelHelper.Spacing="4">
                            <TextBlock Text="Position" FontSize="12" Opacity="0.6" />
                            <ui:ComboBox ItemsSource="{Binding Positions}" SelectedItem="{Binding WatermarkPosition}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="8,0,0,0" helpers:StackPanelHelper.Spacing="4">
                            <TextBlock Text="Font Size" FontSize="12" Opacity="0.6" />
                            <Slider Value="{Binding WatermarkFontSize}" Minimum="0.01" Maximum="0.1" TickFrequency="0.01" TickPlacement="BottomRight" Width="120" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="8,0,0,0" helpers:StackPanelHelper.Spacing="4">
                            <TextBlock Text="Opacity" FontSize="12" Opacity="0.6" />
                            <Slider Value="{Binding WatermarkOpacity}" Minimum="0.1" Maximum="1.0" TickFrequency="0.1" TickPlacement="BottomRight" Width="120" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── Color Grading ── -->
            <Border Style="{StaticResource CardBorderStyle}" Padding="20" CornerRadius="8">
                <StackPanel helpers:StackPanelHelper.Spacing="12">
                    <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="8">
                        <ui:SymbolIcon Symbol="Adjust24" FontSize="18" />
                        <TextBlock Text="Color Grading" FontWeight="Medium" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="16">
                        <CheckBox Content="Enable color grading" IsChecked="{Binding EnableColorGrading}" />
                        <ui:ComboBox ItemsSource="{Binding ColorGrades}" SelectedItem="{Binding ColorGradePreset}"
                                     IsEnabled="{Binding EnableColorGrading}" MinWidth="140" />
                    </StackPanel>
                    <TextBlock Text="Cinematic presets applied via FFmpeg curves and eq filters" FontSize="12" Opacity="0.5" />
                </StackPanel>
            </Border>

            <!-- ── Audio Identity ── -->
            <Border Style="{StaticResource CardBorderStyle}" Padding="20" CornerRadius="8">
                <StackPanel helpers:StackPanelHelper.Spacing="12">
                    <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="8">
                        <ui:SymbolIcon Symbol="Audio24" FontSize="18" />
                        <TextBlock Text="Audio Identity" FontWeight="Medium" />
                    </StackPanel>
                    <!-- Intro Audio -->
                    <Grid ColumnDefinitions="*,Auto">
                        <ui:TextBox Grid.Column="0" Text="{Binding IntroAudioPath, Mode=OneWay}" PlaceholderText="Intro audio (brand sting/swoosh)" IsReadOnly="True" />
                        <ui:Button Grid.Column="1" Content="Browse" Command="{Binding BrowseIntroAudioCommand}" Margin="8,0,0,0" Padding="16,6" />
                    </Grid>
                    <!-- Outro Audio -->
                    <Grid ColumnDefinitions="*,Auto">
                        <ui:TextBox Grid.Column="0" Text="{Binding OutroAudioPath, Mode=OneWay}" PlaceholderText="Outro audio" IsReadOnly="True" />
                        <ui:Button Grid.Column="1" Content="Browse" Command="{Binding BrowseOutroAudioCommand}" Margin="8,0,0,0" Padding="16,6" />
                    </Grid>
                    <!-- Background Music -->
                    <Grid ColumnDefinitions="*,Auto">
                        <ui:TextBox Grid.Column="0" Text="{Binding BackgroundMusicPath, Mode=OneWay}" PlaceholderText="Default background music" IsReadOnly="True" />
                        <ui:Button Grid.Column="1" Content="Browse" Command="{Binding BrowseMusicCommand}" Margin="8,0,0,0" Padding="16,6" />
                    </Grid>
                    <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="8">
                        <TextBlock Text="Music Volume:" VerticalAlignment="Center" />
                        <Slider Value="{Binding MusicVolume}" Minimum="0" Maximum="1" TickFrequency="0.1" TickPlacement="BottomRight" Width="200" />
                        <TextBlock Text="{Binding MusicVolume, StringFormat={}{0:F1}}" VerticalAlignment="Center" Margin="8,0,0,0" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ── Video Bumpers ── -->
            <Border Style="{StaticResource CardBorderStyle}" Padding="20" CornerRadius="8">
                <StackPanel helpers:StackPanelHelper.Spacing="12">
                    <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="8">
                        <ui:SymbolIcon Symbol="FilmClip24" FontSize="18" />
                        <TextBlock Text="Video Bumpers (Intro/Outro)" FontWeight="Medium" />
                    </StackPanel>
                    <Grid ColumnDefinitions="*,Auto">
                        <ui:TextBox Grid.Column="0" Text="{Binding IntroVideoPath, Mode=OneWay}" PlaceholderText="Intro video bumper" IsReadOnly="True" />
                        <ui:Button Grid.Column="1" Content="Browse" Command="{Binding BrowseIntroVideoCommand}" Margin="8,0,0,0" Padding="16,6" />
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <ui:TextBox Grid.Column="0" Text="{Binding OutroVideoPath, Mode=OneWay}" PlaceholderText="Outro video bumper" IsReadOnly="True" />
                        <ui:Button Grid.Column="1" Content="Browse" Command="{Binding BrowseOutroVideoCommand}" Margin="8,0,0,0" Padding="16,6" />
                    </Grid>
                    <TextBlock Text="Bumpers are prepended/appended to the final stitched video" FontSize="12" Opacity="0.5" />
                </StackPanel>
            </Border>

            <!-- ── Actions ── -->
            <StackPanel Orientation="Horizontal" helpers:StackPanelHelper.Spacing="12">
                <ui:Button Content="Save Brand" Icon="{ui:SymbolIcon Save24}" Appearance="Primary" Command="{Binding SaveCommand}" Padding="24,10" />
                <ui:Button Content="Clear All" Appearance="Secondary" Command="{Binding ClearBrandingCommand}" Padding="20,10" />
            </StackPanel>

            <!-- ── Status ── -->
            <TextBlock Text="{Binding StatusMessage}" FontSize="13" Opacity="0.6" TextWrapping="Wrap" />

        </StackPanel>
    </Grid>
</Page>
